<customUI xmlns="http://schemas.microsoft.com/office/2006/01/customui">
    <ribbon startFromScratch="false">
        <tabs>
            <tab id="et-toolkit" label="ET Toolkit">
                <group id="default-group" label="default-group">
                    <!-- 学分汇总（计算完成进度） -->
                    <splitButton id="dialog/credit-summary/calculate-progress/latest-version" getImage="getImage">
                        <button id="dialog/credit-summary/calculate-progress/version-20260622A" label="学分汇总（计算完成进度）" onAction="onAction"></button>
                    </splitButton>
                    <!-- 学分汇总（计算有效学分） -->
                    <splitButton id="dialog/credit-summary/calculate-valid-credits/latest-version" getImage="getImage">
                        <button id="dialog/credit-summary/calculate-valid-credits/version-20260622A" label="学分汇总（计算有效学分）" onAction="onAction"></button>
                        <menu id="dialog/credit-summary/calculate-valid-credits/old-versions">
                            <button id="dialog/credit-summary/calculate-valid-credits/version-20260125A" label="旧版本 - 20260125A" onAction="onAction"></button>
                            <button id="dialog/credit-summary/calculate-valid-credits/version-20260122A" label="旧版本 - 20260122A" onAction="onAction"></button>
                            <button id="dialog/credit-summary/calculate-valid-credits/version-20260116A" label="旧版本 - 20260116A" onAction="onAction"></button>
                        </menu>
                    </splitButton>
                    <!-- 汇总+明细（检查毕业资格） -->
                    <splitButton id="dialog/detail-and-summary/check-graduation-qualification/latest-version" getImage="getImage">
                        <button id="dialog/detail-and-summary/check-graduation-qualification/version-20260620A" label="汇总+明细（检查毕业资格）" onAction="onAction"></button>
                        <menu id="dialog/detail-and-summary/check-graduation-qualification/old-versions">
                            <button id="dialog/detail-and-summary/check-graduation-qualification/version-20260619A" label="旧版本 - 20260619A" onAction="onAction"></button>
                            <button id="dialog/detail-and-summary/check-graduation-qualification/version-20260126A" label="旧版本 - 20260126A" onAction="onAction"></button>
                        </menu>
                    </splitButton>
                    <button id="version-button" label="版本 - 20260622A" getImage="getImage"></button>
                </group>
            </tab>
        </tabs>
    </ribbon>
</customUI>